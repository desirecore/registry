{
  "id": "db-mcp",
  "name": "Database MCP",
  "type": "mcp",
  "version": "0.6.2",
  "author": "Anthropic",
  "description": "PostgreSQL 数据库查询与管理，支持 SQL 执行和 Schema 浏览",
  "tags": [
    "数据库",
    "PostgreSQL",
    "SQL"
  ],
  "icon": "terminal",
  "platformSupport": [
    "macos",
    "windows",
    "linux"
  ],
  "capabilities": [
    "sql_query",
    "schema_browse",
    "data_export"
  ],
  "toolCount": 1,
  "install": {
    "method": "npx",
    "packageName": "@modelcontextprotocol/server-postgres",
    "command": "npx",
    "args": [
      "-y",
      "@modelcontextprotocol/server-postgres",
      "postgresql://localhost/mydb"
    ]
  },
  "connection": {
    "transport": "stdio",
    "command": "npx",
    "args": [
      "-y",
      "@modelcontextprotocol/server-postgres",
      "postgresql://localhost/mydb"
    ]
  }
}
