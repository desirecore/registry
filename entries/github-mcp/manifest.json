{
  "id": "github-mcp",
  "name": "GitHub MCP",
  "type": "mcp",
  "version": "0.32.0",
  "author": "GitHub",
  "description": "代码仓库操作，支持 PR、Issue、代码搜索和仓库管理",
  "tags": [
    "代码",
    "Git",
    "PR"
  ],
  "icon": "terminal",
  "platformSupport": [
    "macos",
    "windows",
    "linux"
  ],
  "capabilities": [
    "repo_read",
    "pr_manage",
    "issue_manage",
    "code_search"
  ],
  "toolCount": 51,
  "install": {
    "method": "docker",
    "packageName": "ghcr.io/github/github-mcp-server",
    "command": "docker",
    "args": [
      "run",
      "-i",
      "--rm",
      "-e",
      "GITHUB_PERSONAL_ACCESS_TOKEN",
      "ghcr.io/github/github-mcp-server"
    ],
    "env": {
      "GITHUB_PERSONAL_ACCESS_TOKEN": "<your-token>"
    }
  },
  "connection": {
    "transport": "stdio",
    "command": "docker",
    "args": [
      "run",
      "-i",
      "--rm",
      "-e",
      "GITHUB_PERSONAL_ACCESS_TOKEN",
      "ghcr.io/github/github-mcp-server"
    ]
  }
}
